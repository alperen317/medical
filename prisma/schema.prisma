generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  permissions String[]
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  roleId           String
  passwordHash     String
  setupToken       String?   @unique
  setupTokenExpiry DateTime?
  // Atandığı hasta bu durumlardan birine geçince kullanıcıya e-posta gönderilir.
  notifyPatientStatuses PatientStatus[] @default([])
  // Hasta üzerinde belirli aksiyonlar (belge yükleme, reçete yazma vb.) yapıldığında bildirim al.
  notifyOnActions NotificationAction[] @default([])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  role                Role            @relation(fields: [roleId], references: [id])
  departments         Department[]
  timelineEvents      TimelineEvent[]
  diagnoses           Diagnosis[]
  prescriptions       Prescription[]
  patients            Patient[]       @relation("AssignedDoctor")
  activityLogs        ActivityLog[]
  doctorAppointments  Appointment[]   @relation("DoctorAppointments")
  createdAppointments Appointment[]   @relation("CreatedAppointments")
  notifications       Notification[]
  aiReportRatings     AiReportRating[]

  @@index([roleId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorId])
  @@index([entityType])
}

enum PatientStatus {
  active
  inactive
  critical
  discharged
}

enum NotificationAction {
  report_added
  prescription_added
}

enum Gender {
  male
  female
  other
}

enum BloodType {
  A_pos  @map("A+")
  A_neg  @map("A-")
  B_pos  @map("B+")
  B_neg  @map("B-")
  AB_pos @map("AB+")
  AB_neg @map("AB-")
  O_pos  @map("O+")
  O_neg  @map("O-")
}

enum TimelineEventType {
  visit
  diagnosis
  treatment
  note
  document
  prescription
  lab
}

enum DiagnosisSeverity {
  mild
  moderate
  severe
}

enum DiagnosisStatus {
  active
  resolved
  chronic
}

model Patient {
  id                       String        @id @default(cuid())
  tcNo                     String?       @unique
  firstName                String
  lastName                 String
  dateOfBirth              DateTime
  gender                   Gender
  bloodType                BloodType?
  phone                    String
  email                    String?
  address                  String?
  status                   PatientStatus @default(active)
  allergies                String[]
  chronicConditions        String[]
  assignedDoctorId         String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  aiSummary                String?
  aiSummaryData            Json?
  aiSummaryAt              DateTime?
  aiSummaryById            String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  assignedDoctor  User?            @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id])
  timelineEvents  TimelineEvent[]
  diagnoses       Diagnosis[]
  prescriptions   Prescription[]
  appointments    Appointment[]
  aiReportRatings AiReportRating[]
  // ClinicalOS kabul süreçleri — bu hastayı otomatik oluşturan/eşleşen
  // WorkflowInstance kayıtları (bkz. WorkflowInstance.promotedPatientId).
  intakeInstances WorkflowInstance[]

  @@index([status])
  @@index([assignedDoctorId])
}

// AI çıktısı geri bildirimi: LLM'e gönderilen istem, üretilen sonuç ve kullanıcı puanı.
model AiReportRating {
  id           String   @id @default(cuid())
  source       String   @default("patient_summary") // hangi AI özelliği
  patientId    String?
  systemPrompt String?  // LLM sistem mesajı (persona + format talimatı)
  prompt       String   // LLM kullanıcı mesajı (veri bloğu + görev talimatı)
  result       String   // LLM'in ürettiği sonuç (assistant mesajı)
  rating       Int      // 👍 = 1, 👎 = -1
  comment      String?
  correctedResult String? // 👎 durumunda değerlendirenin yazdığı "ideal" çıktı (altın SFT verisi)
  reasons      String[] // yapısal 👎 nedenleri: hallucination, missed_finding, wrong_tone, unsafe, other
  model        String?
  ratedById    String
  createdAt    DateTime @default(now())

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  ratedBy User     @relation(fields: [ratedById], references: [id])

  @@index([patientId])
  @@index([source])
}

model TimelineEvent {
  id          String            @id @default(cuid())
  patientId   String
  type        TimelineEventType
  title       String
  description String
  date        DateTime
  createdById String
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id])
  attachments Attachment[]

  @@index([patientId, date])
  @@index([type])
}

model Attachment {
  id      String @id @default(cuid())
  eventId String
  name    String
  url     String
  size    Int
  type    String

  event TimelineEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id            String            @id @default(cuid())
  patientId     String
  name          String
  icdCode       String?
  description   String?
  severity      DiagnosisSeverity
  status        DiagnosisStatus   @default(active)
  diagnosedAt   DateTime
  diagnosedById String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  diagnosedBy User    @relation(fields: [diagnosedById], references: [id])

  @@index([patientId])
}

model Prescription {
  id             String   @id @default(cuid())
  patientId      String
  medication     String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  active         Boolean  @default(true)
  prescribedAt   DateTime
  prescribedById String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescribedBy User    @relation(fields: [prescribedById], references: [id])

  @@index([patientId])
}

enum AppointmentStatus {
  scheduled
  completed
  cancelled
  no_show
}

enum AppointmentType {
  consultation
  follow_up
  procedure
  lab
  other
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  scheduledAt DateTime
  duration    Int               @default(30)
  type        AppointmentType   @default(consultation)
  status      AppointmentStatus @default(scheduled)
  notes       String?
  createdById String
  reminderSentAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User    @relation("DoctorAppointments",  fields: [doctorId],    references: [id])
  createdBy User    @relation("CreatedAppointments", fields: [createdById], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt(sort: Desc)])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════
// ClinicalOS v2 — metadata-driven workflow platformu (v1 klinik modellerinden
// bağımsız, FK ilişkisi yok; bkz. ClinicalOS_MLP_Onkoloji_Tasarim_Dokumani.docx)
// ═══════════════════════════════════════════════════════════════════════════

enum WorkflowDefinitionStatus {
  draft
  published
}

enum WorkflowInstanceStatus {
  in_progress
  completed
}

model WorkflowDefinition {
  id        String                   @id @default(cuid())
  name      String
  branch    String                   // örn. "onkoloji" — çekirdek branştan bağımsız kalır
  version   Int                      @default(1)
  status    WorkflowDefinitionStatus @default(draft)
  // node graph: { nodes: [{ id, type: start|form|decision|document|task|end, config }], edges: [...] }
  nodes     Json
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  instances WorkflowInstance[]

  @@index([branch, status])
}

model FormDefinition {
  id        String   @id @default(cuid())
  // Versiyon ailesi kimliği — bir formun ilk versiyonunun id'siyle aynıdır.
  // Workflow node'ları (formId) her zaman tek bir versiyonun (bu tablonun bir
  // satırının) id'sine sabitlenir; satırlar hiçbir zaman yerinde değiştirilmez
  // (immutable snapshot) — düzenleme her zaman rootId aynı kalacak şekilde yeni
  // bir satır/versiyon oluşturur. Böylece zaten kullanımda olan workflow'lar ve
  // instance'lar hep gördükleri alan setini (id/tip) korur.
  rootId    String
  version   Int      @default(1)
  isLatest  Boolean  @default(true)
  name      String
  // field metadata: [{ id, type: text|number|date|boolean|select|textarea|file, label, required, options?, visibleIf? }]
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rootId])
}

model RuleDefinition {
  id        String   @id @default(cuid())
  name      String
  // basit koşul objesi: { field, operator, value, then, else } — Form alan id'lerine referans verir
  condition Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PatientV2 {
  id           String   @id @default(cuid())
  tcNo         String?  @unique
  firstName    String
  lastName     String
  dateOfBirth  DateTime
  gender       Gender
  phone        String
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflowInstances WorkflowInstance[]
}

model WorkflowInstance {
  id               String                  @id @default(cuid())
  patientId        String
  workflowDefId    String
  workflowVersion  Int
  currentNodeId    String
  status           WorkflowInstanceStatus  @default(in_progress)
  // form cevapları: { [formFieldId]: value }
  answers          Json                    @default("{}")
  // tamamlanan görevler / bekleyen görevler
  tasks            Json                    @default("[]")
  // ziyaret edilen actionable node id'lerinin sırası — "Geri" navigasyonu için
  history          Json                    @default("[]")
  startedAt        DateTime                @default(now())
  completedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  // "end" node'una ulaşılınca (hasta doktora hazır) otomatik oluşturulan/eşleşen
  // gerçek Patient kaydı — /patients sayfasında bu kabul sürecinin Son Kontrol
  // özetini birebir göstermek için (bkz. promotePatientFromIntake).
  promotedPatientId String?

  patient          PatientV2               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  workflowDef      WorkflowDefinition      @relation(fields: [workflowDefId], references: [id])
  documents        WorkflowDocument[]
  promotedPatient  Patient?                @relation(fields: [promotedPatientId], references: [id])

  @@index([patientId])
  @@index([workflowDefId])
  @@index([status])
  @@index([promotedPatientId])
}

model WorkflowDocument {
  id                 String   @id @default(cuid())
  workflowInstanceId String
  nodeId             String
  // Bu belgenin ait olduğu document node checklist kalemi (DocumentChecklistItem.label).
  // Checklist kaleminin kararlı bir id'si yok (bkz. workflow/types.ts) — Studio'da
  // kalemler yalnızca label/required üzerinden düzenlendiği için eşleşme label
  // metnine göre yapılıyor. null: checklist'te karşılığı olmayan ek/serbest yükleme.
  checklistLabel     String?
  name               String
  url                String
  size               Int
  type               String
  createdAt          DateTime @default(now())

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([workflowInstanceId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  body       String
  entityType String?
  entityId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}
